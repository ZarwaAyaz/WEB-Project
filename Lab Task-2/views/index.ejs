<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Honey, I'm home Accessories.</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('header') %>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <div class="hero-overlay">
                <button class="shop-all-btn">Shop all</button>
            </div>
        </div>
    </section>

    <!-- Bestsellers Section -->
    <section class="bestsellers-section">
        <h2 class="section-title">BESTSELLERS!</h2>
        
        <div class="product-grid">
            <!-- Product 1 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Elise Vintage Ring.webp" alt="Elise Vintage Ring">
                    <span class="badge sold-out">Sold out</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Elise Vintage Ring</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,650.00 PKR</span>
                        <span class="sale-price">Rs.1,100.00 PKR</span>
                    </div>
                    <button class="btn-outline">Choose more options</button>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Solid Heart Necklace.webp" alt="Solid Heart Necklace">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Solid Heart Necklace</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,850.00 PKR</span>
                        <span class="sale-price">Rs.1,550.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Nola Bracelet.webp" alt="Nola Bracelet">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Nola Bracelet</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.2,250.00 PKR</span>
                        <span class="sale-price">Rs.1,690.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 4 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Cosmina Ring.webp" alt="Cosmina Ring">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Cosmina Ring</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,950.00 PKR</span>
                        <span class="sale-price">Rs.1,450.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 5 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Encrusted Hoops.webp" alt="Encrusted Hoops">
                    <span class="badge sold-out">Sold out</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Encrusted Hoops</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.2,250.00 PKR</span>
                        <span class="sale-price">Rs.1,950.00 PKR</span>
                    </div>
                    <button class="btn-outline">Choose more options</button>
                </div>
            </div>

            <!-- Product 6 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Be Grateful Bracelet.webp" alt="Be Grateful Bracelet">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Be Grateful Bracelet</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,950.00 PKR</span>
                        <span class="sale-price">Rs.1,550.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 7 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Hailey Bieber Bottega Gold Hoops.webp" alt="Hailey Bieber Bottega Gold Hoops">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Hailey Bieber Bottega Gold Hoops</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.2,950.00 PKR</span>
                        <span class="sale-price">Rs.1,900.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 8 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Chain Bracelet.webp" alt="Chain Bracelet">
                </div>
                <div class="product-info">
                    <h3 class="product-name">Chain Bracelet</h3>
                    <div class="product-price">
                        <span class="sale-price">Rs.1,350.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>
        </div>

        <div class="view-all-container">
            <button class="btn-dark">View all</button>
        </div>
    </section>

    <!-- New Products Section -->
    <section class="new-products-section">
        <h2 class="section-title">NEW PRODUCTS!</h2>
        
        <div class="product-grid">
            <!-- Product 1 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Purple Bouqet Earring.webp" alt="Purple Bouquet Earrings" class="img-default">
                    <img src="/images/Purple Bouqet Earrings 2.webp" alt="Purple Bouquet Earrings" class="img-hover">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Purple Bouquet Earrings</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.4,950.00 PKR</span>
                        <span class="sale-price">Rs.4,180.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Confetti Butterfly Earring.webp" alt="Confetti Butterfly Earrings" class="img-default">
                    <img src="/images/Confetti Butterfly Earrings 2.webp" alt="Confetti Butterfly Earrings" class="img-hover">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Confetti Butterfly Earrings</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.4,950.00 PKR</span>
                        <span class="sale-price">Rs.3,950.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Mini Pink Shell Necklace.webp" alt="Mini Pink Shell Necklace" class="img-default">
                    <img src="/images/Mini Pink Shell Necklace 2.webp" alt="Mini Pink Shell Necklace" class="img-hover">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Mini Pink Shell Necklace</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,950.00 PKR</span>
                        <span class="sale-price">Rs.1,350.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>

            <!-- Product 4 -->
            <div class="product-card">
                <div class="product-image">
                    <img src="/images/Pink Silver Necklace.webp" alt="Pink Silver Necklace" class="img-default">
                    <img src="/images/Pink silver Necklace 2.webp" alt="Pink Silver Necklace" class="img-hover">
                    <span class="badge sale">Sale</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Pink Silver Necklace</h3>
                    <div class="product-price">
                        <span class="original-price">Rs.1,950.00 PKR</span>
                        <span class="sale-price">Rs.1,450.00 PKR</span>
                    </div>
                    <button class="btn-outline">Add to cart</button>
                </div>
            </div>
        </div>

        <div class="view-all-container">
            <button class="btn-dark">View all</button>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-section">
        <div class="about-container">
            <h2 class="about-title">ABOUT US!</h2>
            <p class="about-text">
                Honey, I'm Home Accessories is built on the belief that luxury should feel effortless. We create timeless, beautifully crafted accessories that elevate everyday moments but without the hefty price tag. Each piece is made with high-quality, sustainable stainless steel, giving you lasting durability, confidence, and style you can rely on day after day.
            </p>
        </div>
    </section>

    <%- include('footer') %>

    <script src="/js/script.js"></script>
</body>
</html>
